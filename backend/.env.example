MONGO_URL="mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority"
DB_NAME="letssnog"
APP_NAME="letssnog"

# CORS (comma-separated)
CORS_ORIGINS="https://your-vercel-app.vercel.app,http://localhost:3000"

# AWS Cognito (User Pool)
COGNITO_REGION="eu-west-2"
COGNITO_USER_POOL_ID="eu-west-2_XXXXXXXXX"
COGNITO_APP_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxx"

# S3 (public URL base recommended if storing photo keys)
AWS_REGION="eu-west-2"
S3_BUCKET="your-photo-bucket"
S3_PUBLIC_BASE_URL="https://your-photo-bucket.s3.eu-west-2.amazonaws.com"

# Bedrock (optional)
ENABLE_SNOG_AI="false"
BEDROCK_REGION="eu-west-2"
BEDROCK_MODEL_ID="anthropic.claude-3-5-sonnet-20240620-v1:0"

